# =============================================
# Next.js + React Project .gitignore
# =============================================

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs
.next/
out/
build/

# Environment variables (CRITICAL - keeps your EmailJS keys private)
.env
.env*.local
.env*.development
.env*.production

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
/coverage

# Misc
.DS_Store
*.pem

# Editor / IDE files
.vscode/
.idea/
*.swp
*.swo

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Personal / sensitive files
# Tannor_Wallace_Resume.pdf
# Tannor_Wallace_Res_*.pdf
# *.pdf
# public/resources/*.pdf

# Temporary / cache
.tmp
temp
.cache